{
  "name": "sudoku-game",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astrobuild",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest",
    "vite:dev": "vite",
    "vite:build": "tsc -b && vite build && cp dist/index.html dist/404.html",
    "vite:preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "comments": {
    "Note 1": "predeploy runs automatically before deploy",
    "Note 2": "gh-pages pushes the dist folder to GitHub Pages"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.14.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitejs/plugin-vue": "^6.0.1",
    "jsdom": "^29.1.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^6.2.0",
    "vite-plugin-svgr": "^4.5.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/react": "^5.0.4",
    "@emailjs/browser": "^4.4.1",
    "astro": "^6.2.2",
    "postcss": "^8.5.12",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.9.1"
  }
}
