---
import AstroLayout from "../layouts/Layout.astro";
import SudokuTipsPage from "../ReactPages/SudokuTips.tsx";
---

<AstroLayout title="Sudoku Tips | Sudoku Plays">
    <SudokuTipsPage client:load />
</AstroLayout>
<script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@graph": [
            {
                "@type": "WebPage",
                "@id": "https://sudokuplays.com/Tips/#webpage",
                "url": "https://sudokuplays.com/Tips/",
                "name": "Sudoku Tips & Strategies | Sudoku Plays",
                "description": "Master Sudoku with our comprehensive guide to strategies including Cross-hatching, Naked Pairs, X-Wing, and more.",
                "breadcrumb": {
                    "@id": "https://sudokuplays.com/Tips/#breadcrumb"
                },
                "inLanguage": "en",
                "isPartOf": {
                    "@type": "WebSite",
                    "@id": "https://sudokuplays.com/#website",
                    "name": "Sudoku Plays",
                    "url": "https://sudokuplays.com/"
                }
            },
            {
                "@type": "BreadcrumbList",
                "@id": "https://sudokuplays.com/Tips/#breadcrumb",
                "itemListElement": [
                    {
                        "@type": "ListItem",
                        "position": 1,
                        "item": {
                            "@type": "WebPage",
                            "@id": "https://sudokuplays.com/",
                            "url": "https://sudokuplays.com/",
                            "name": "Home"
                        }
                    },
                    {
                        "@type": "ListItem",
                        "position": 2,
                        "item": {
                            "@id": "https://sudokuplays.com/Tips/",
                            "name": "Sudoku Tips"
                        }
                    }
                ]
            },
            {
                "@type": "HowTo",
                "name": "How to Master Sudoku Strategies",
                "description": "A step-by-step guide to essential and advanced Sudoku solving techniques.",
                "step": [
                    {
                        "@type": "HowToStep",
                        "name": "Cross-hatching",
                        "text": "Eliminate candidates by scanning rows, columns, and 3x3 blocks.",
                        "position": 1
                    },
                    {
                        "@type": "HowToStep",
                        "name": "Naked Singles & Hidden Singles",
                        "text": "Identify cells with only one possible candidate or numbers that can only fit in one cell within a region.",
                        "position": 2
                    },
                    {
                        "@type": "HowToStep",
                        "name": "Naked Pairs & Hidden Pairs",
                        "text": "Find two cells in a region that share the same two candidates exclusively to eliminate those candidates elsewhere.",
                        "position": 3
                    },
                    {
                        "@type": "HowToStep",
                        "name": "Pointing Pairs / Triples",
                        "text": "Restricted candidates within a block can eliminate possibilities in the rest of the row or column.",
                        "position": 4
                    },
                    {
                        "@type": "HowToStep",
                        "name": "X-Wing",
                        "text": "An advanced elimination technique using two rows and two columns to lock candidate positions.",
                        "position": 5
                    }
                ]
            }
        ]
    }
</script>
