---
import AstroLayout from "../layouts/Layout.astro";
import ContactPage from "../ReactPages/Contact";
---

<AstroLayout title="Contact | Sudoku Plays">
    <ContactPage client:load />
</AstroLayout>
<script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@graph": [
            {
                "@type": "ContactPage",
                "@id": "https://sudokuplays.com/contact/#webpage",
                "url": "https://sudokuplays.com/contact/",
                "name": "Contact Us | Sudoku Plays",
                "description": "Have questions or feedback about our Sudoku games? Reach out to the SudokuPlays team for support and suggestions.",
                "breadcrumb": {
                    "@id": "https://sudokuplays.com/contact/#breadcrumb"
                },
                "inLanguage": "en",
                "isPartOf": {
                    "@type": "WebSite",
                    "@id": "https://sudokuplays.com/#website",
                    "name": "Sudoku Plays",
                    "url": "https://sudokuplays.com/"
                }
            },
            {
                "@type": "BreadcrumbList",
                "@id": "https://sudokuplays.com/contact/#breadcrumb",
                "itemListElement": [
                    {
                        "@type": "ListItem",
                        "position": 1,
                        "item": {
                            "@type": "WebPage",
                            "@id": "https://sudokuplays.com/",
                            "url": "https://sudokuplays.com/",
                            "name": "Home"
                        }
                    },
                    {
                        "@type": "ListItem",
                        "position": 2,
                        "item": {
                            "@id": "https://sudokuplays.com/contact/",
                            "name": "Contact"
                        }
                    }
                ]
            },
            {
                "@type": "Organization",
                "name": "Sudoku Plays",
                "url": "https://sudokuplays.com/",
                "logo": "https://sudokuplays.com/images/png/logo_sudoku1.png",
                "contactPoint": {
                    "@type": "ContactPoint",
                    "email": "site.help@gmail.com",
                    "contactType": "customer service",
                    "availableLanguage": "en"
                }
            }
        ]
    }
</script>
