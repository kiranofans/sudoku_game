---
import AstroLayout from "../layouts/Layout.astro";
import ContactPage from "../ReactPages/Contact";
---

<AstroLayout title="Contact | Sudoku">
    <ContactPage client:load />
</AstroLayout>
<script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "ContactPage",
        "name": "Sudoku Play's Contact Us",
        "description": "Have questions or feedback about our Sudoku games? Reach out to the SudokuPlays team for support.",
        "alternateName": "Sudoku Game Site Contact Page",
        "applicationCategory": "Game",
        "operatingSystem": "Web",
        "url": "https://sudokuplays.com/contact/",

        "mainEntity": {
            "@type": "Organization",
            "name": "SudokuPlay",
            "url": "https://sudokuplays.com",
            "contactPoint": {
                "@type": "ContactPoint",
                "email": "site.help@gmail.com",
                "contactType": "customer service",
                "availableLanguage": "en,cn,jp,fr"
            }
        },
        "offers": {
            "@type": "Offer",
            "price": "0",
            "priceCurrency": "USD"
        },
        "screenshot": "https://sudokugameplay.com/og-image.png",
        "inLanguage": "English",
        "softwareVersion": "1.0",
        "keywords": [
            "Sudoku",
            "Online Sudoku",
            "Quick Contact",
            "Brain Game",
            "Help & Support",
            "Found bugs?",
            "Performance improvements",
            "New features",
            "Suggestions?",
            "General feedback",
            "Feedbacks",
            "Conatact sudokuplays.com",
            "Contact Us",
            "Questions?",
            "What's New?",
            "Changelog",
            "Contact us Sudoku",
            "Send Message",
            "Ideas",
            "Send Feedback",
            "Subject",
            "Email address",
            "Submit"
        ],
        "genre": "Puzzle Game",
        "featureList": [
            "Easy & quick contact",
            "send feedback",
            "Subject",
            "Message",
            "Submit button",
            "Responsive Design",
            "No Signup Required",
            "Send message imediately",
            "Get quick response",
            "Get response by email"
        ]
    }
</script>
