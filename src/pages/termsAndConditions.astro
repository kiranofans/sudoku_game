---
import AstroLayout from "../layouts/Layout.astro";
import TermsConditionsPage from "../ReactPages/TermsAndConditions.tsx";
---

<AstroLayout title="Terms & Conditions | Sudoku Plays">
    <TermsConditionsPage client:load />
</AstroLayout>
<script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@graph": [
            {
                "@type": "WebPage",
                "@id": "https://sudokuplays.com/termsAndConditions/#webpage",
                "url": "https://sudokuplays.com/termsAndConditions/",
                "name": "Terms and Conditions | Sudoku Plays",
                "description": "Read the terms and conditions for using Sudoku Plays. Understand your rights and responsibilities while playing on our site.",
                "breadcrumb": {
                    "@id": "https://sudokuplays.com/termsAndConditions/#breadcrumb"
                },
                "inLanguage": "en",
                "isPartOf": {
                    "@type": "WebSite",
                    "@id": "https://sudokuplays.com/#website",
                    "name": "Sudoku Plays",
                    "url": "https://sudokuplays.com/"
                }
            },
            {
                "@type": "BreadcrumbList",
                "@id": "https://sudokuplays.com/termsAndConditions/#breadcrumb",
                "itemListElement": [
                    {
                        "@type": "ListItem",
                        "position": 1,
                        "item": {
                            "@type": "WebPage",
                            "@id": "https://sudokuplays.com/",
                            "url": "https://sudokuplays.com/",
                            "name": "Home"
                        }
                    },
                    {
                        "@type": "ListItem",
                        "position": 2,
                        "item": {
                            "@id": "https://sudokuplays.com/termsAndConditions/",
                            "name": "Terms & Conditions"
                        }
                    }
                ]
            }
        ]
    }
</script>
