---
import AstroLayout from "../layouts/Layout.astro";
import ChangeLogPage from "../ReactPages/ChangeLog.tsx";
---

<AstroLayout title="Change Log | Sudoku Plays">
    <ChangeLogPage client:load />
</AstroLayout>

<script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "What's New?",
        "alternateName": "Sudoku Game Site Change Log",
        "applicationCategory": "Game",
        "operatingSystem": "Web",
        "url": "https://sudokuplays.com/ChangeLog/",
        "offers": {
            "@type": "Offer",
            "price": "0",
            "priceCurrency": "USD"
        },
        "screenshot": "https://sudokugameplay.com/og-image.png",
        "inLanguage": "English",
        "softwareVersion": "1.0",
        "description": "Keeping sudokuplays.com fresh, fast, and easy to use. Here’s what’s new, what’s fixed, and what’s on the way.",
        "keywords": [
            "Sudoku",
            "Free Online Sudoku",
            "Number Puzzle",
            "Free Brain Game",
            "Puzzle Game bug fixes",
            "Bug fixes",
            "Performance improvements",
            "New features",
            "Known issues box",
            "fixes",
            "New Improvements",
            "What's New",
            "What's new page",
            "Changelog",
            "Change Log Sudoku",
            "Change Log Sudoku Game"
            "Change Log page",
        ],
        "genre": "Update Log",
        "featureList": [
            "Hint System",
            "Timer and Stats",
            "Score System",
            "Theme System",
            "Responsive Design",
            "Improvement and bug fixes",
            "Change log",
            "Features update",
            "Actively updating",
            "New features",
            "Known issues box",
            "What's New",
        ]
    }
</script>
