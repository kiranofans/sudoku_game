---
import Layout from "../layouts/Layout.astro";
import Homepage from "../ReactPages/Homepage.tsx";
import "../styles.css";
---

<Layout title="SudokuPlays - Play Online">
    <Homepage client:load />
</Layout>
<script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@graph": [
            {
                "@type": "WebSite",
                "name": "SudokuPlays",
                "url": "https://sudokuplays.com/",
                "potentialAction": {
                    "@type": "SearchAction",
                    "target": "https://sudokuplays.com/?s={search_term_string}",
                    "query-input": "required name=search_term_string"
                }
            },
            {
                "@type": "SoftwareApplication",
                "name": "SudokuPlay",
                "alternateName": "Free Sudoku Game Online",
                "applicationCategory": "GameApplication",
                "operatingSystem": "Web",
                "description": "Play Sudoku online for free. Featuring a responsive, glassy UI, multiple difficulty levels, and daily challenges.",
                "offers": {
                    "@type": "Offer",
                    "price": "0",
                    "priceCurrency": "USD"
                },
                "keywords": [
                    "SudokuPlay",
                    "Sudoku",
                    "Multiple Difficulty Levels",
                    "Mobile Responsive Design",
                    "Glassy UI Animations",
                    "No Signup Required",
                    "Timer and Stats",
                    "Score System",
                    "Theme System",
                    "Dark Mode",
                    "Light Mode",
                    "Responsive Design",
                    "Daily Challenges",
                    "Notes/Pencil Marks",
                    "Statistics Tracking",
                    "Game History",
                    "Performance Stats",
                    "Win Rate",
                    "Fast Loading",
                    "Low System Requirements",
                    "Works on all Devices",
                    "Cross-Platform",
                    "One-Click Play",
                    "Instant Start",
                    "No Installation Required",
                    "Puzzle games",
                    "Free online games",
                    "Daily Sudoku",
                    "Brain training",
                    "Logic puzzles",
                    "Mind games",
                    "Number puzzles",
                    "Memory games",
                    "Memory Improvement"
                ],
                "featureList": [
                    "Multiple Difficulty Levels",
