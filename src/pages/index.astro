<meta name="keywords" content="sudoku, sodoku, free sudoku" />
<script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@graph": [
            {
                "@type": "WebSite",
                "@id": "https://sudokuplays.com/#website",
                "url": "https://sudokuplays.com/",
                "name": "Sudoku Plays",
                "description": "Play Sudoku online for free. Featuring a responsive, glassy UI, multiple difficulty levels, and daily challenges.",
                "potentialAction": {
                    "@type": "SearchAction",
                    "target": "https://sudokuplays.com/?s={search_term_string}",
                    "query-input": "required name=search_term_string"
                },
                "inLanguage": "en"
            },
            {
                "@type": "VideoGame",
                "@id": "https://sudokuplays.com/#game",
                "name": "Sudoku Plays",
                "url": "https://sudokuplays.com/",
                "genre": "Puzzle Game",
                "applicationCategory": "GameApplication",
                "operatingSystem": "Web",
                "description": "A modern, logic-based Sudoku puzzle game designed for a smooth and distraction-free experience."
            },
            {
                "@type": "SoftwareApplication",
                "@id": "https://sudokuplays.com/#software",
                "name": "Sudoku Plays",
                "alternateName": "Free Sudoku Game Online",
                "applicationCategory": "GameApplication",
                "operatingSystem": "Web",
                "inLanguage": "en",
                "description": "Play Sudoku online for free. Featuring a responsive, glassy UI, multiple difficulty levels, and daily challenges.",
                "offers": {
                    "@type": "Offer",
                    "price": "0",
                    "priceCurrency": "USD"
                },
                "keywords": [
                    "Sudoku Plays",
                    "Sudoku",
                    "Free Sudoku",
                    "Play Sudoku Online",
                    "Online Sudoku Game",
                    "Classic Sudoku",
                    "Daily Sudoku Puzzle",
                    "Easy Sudoku Online",
                    "Beginner-Friendly Sudoku",
                    "Sudoku with Timer",
                    "Timer and Stats",
                    "Score History",
                    "Sudoku No Login",
                    "Mobile Sudoku",
                    "Free Sudoku for iPad",
                    "Dark Mode",
                    "Casual Puzzle Game",
                    "Brain Training",
                    "Logic Puzzle Game",
                    "Mind Games"
                ],
                "featureList": [
                    "Multiple Difficulty Levels",
                    "Mobile Responsive Design",
                    "No Signup Required",
                    "Timer and Stats Tracking",
                    "Score History",
                    "Theme Switching (Dark/Light)",
                    "Sudoku Tips and Strategies",
                    "Daily Challenges",
                    "Offline Support Capabilities"
                ]
            }
        ]
    }
</script>
