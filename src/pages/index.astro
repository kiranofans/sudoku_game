<script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@graph": [
            {
                "@type": "WebSite",
                "name": "SudokuPlays",
                "url": "https://sudokuplays.com/",
                "potentialAction": {
                    "@type": "SearchAction",
                    "target": "https://sudokuplays.com/?s={search_term_string}",
                    "query-input": "required name=search_term_string"
                }
            },
            {
                "@type": "SoftwareApplication",
                "name": "SudokuPlay",
