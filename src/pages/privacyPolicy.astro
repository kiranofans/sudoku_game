---
import AstroLayout from "../layouts/Layout.astro";
import PrivacyPolicypage from "../ReactPages/PrivacyPolicy.tsx";
---

<AstroLayout title="Privacy Policy | Sudoku Plays">
    <PrivacyPolicypage client:load />
</AstroLayout>
<script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@graph": [
            {
                "@type": "PrivacyPolicy",
                "@id": "https://sudokuplays.com/privacyPolicy/#webpage",
                "url": "https://sudokuplays.com/privacyPolicy/",
                "name": "Privacy Policy | Sudoku Plays",
                "description": "Learn about how Sudoku Plays handles your data and ensures your privacy while you enjoy our games.",
                "breadcrumb": {
                    "@id": "https://sudokuplays.com/privacyPolicy/#breadcrumb"
                },
                "inLanguage": "en",
                "isPartOf": {
                    "@type": "WebSite",
                    "@id": "https://sudokuplays.com/#website",
                    "name": "Sudoku Plays",
                    "url": "https://sudokuplays.com/"
                }
            },
            {
                "@type": "BreadcrumbList",
                "@id": "https://sudokuplays.com/privacyPolicy/#breadcrumb",
                "itemListElement": [
                    {
                        "@type": "ListItem",
                        "position": 1,
                        "item": {
                            "@type": "WebPage",
                            "@id": "https://sudokuplays.com/",
                            "url": "https://sudokuplays.com/",
                            "name": "Home"
                        }
                    },
                    {
                        "@type": "ListItem",
                        "position": 2,
                        "item": {
                            "@id": "https://sudokuplays.com/privacyPolicy/",
                            "name": "Privacy Policy"
                        }
                    }
                ]
            }
        ]
    }
</script>
