---
import AstroLayout from "../layouts/Layout.astro";
import AboutPage from "../ReactPages/About.tsx";
---

<AstroLayout title="About | Sudoku Plays">
    <AboutPage client:load />
</AstroLayout>

<script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@graph": [
            {
                "@type": "AboutPage",
                "@id": "https://sudokuplays.com/about/#webpage",
                "url": "https://sudokuplays.com/about/",
                "name": "About Sudoku Plays",
                "description": "Learn more about Sudoku Plays, a modern and responsive Sudoku game web app. Discover our mission to provide a clean, fast, and accessible puzzle experience for everyone.",
                "breadcrumb": {
                    "@id": "https://sudokuplays.com/about/#breadcrumb"
                },
                "inLanguage": "en",
                "isPartOf": {
                    "@type": "WebSite",
                    "name": "Sudoku Plays",
                    "url": "https://sudokuplays.com/"
                }
            },
            {
                "@type": "BreadcrumbList",
                "@id": "https://sudokuplays.com/about/#breadcrumb",
                "itemListElement": [
                    {
                        "@type": "ListItem",
                        "position": 1,
                        "item": {
                            "@type": "WebPage",
                            "@id": "https://sudokuplays.com/",
                            "url": "https://sudokuplays.com/",
                            "name": "Home"
                        }
                    },
                    {
                        "@type": "ListItem",
                        "position": 2,
                        "item": {
                            "@id": "https://sudokuplays.com/about/",
                            "name": "About"
                        }
                    }
                ]
            },
            {
                "@type": "SoftwareApplication",
                "name": "Sudoku Plays",
                "alternateName": "Free Sudoku Game Online",
                "applicationCategory": "GameApplication",
                "operatingSystem": "Web",
                "url": "https://sudokuplays.com/",
                "image": "https://sudokuplays.com/images/png/logo_sudoku1.png",
                "description": "A logic-based, number-placement puzzle web app featuring multiple difficulty levels and a responsive design.",
                "offers": {
                    "@type": "Offer",
                    "price": "0",
                    "priceCurrency": "USD"
                },
                "publisher": {
                    "@type": "Person",
                    "name": "Kiranofans",
                    "url": "https://github.com/kiranofans"
                },
                "keywords": [
                    "Sudoku",
                    "Online Sudoku",
                    "Brain Game",
                    "Puzzle Game",
                    "Free Sudoku",
                    "Sudoku Strategies",
                    "About Sudoku Plays",
                    "Sudoku Developer"
                ],
                "featureList": [
                    "Multiple Difficulty Levels",
                    "Responsive Design",
                    "Fast Loading",
                    "No Signup Required",
                    "Privacy Focused",
                    "Modern Glassmorphism UI"
                ]
            }
        ]
    }
</script>
