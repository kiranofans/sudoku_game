---
import AstroLayout from "../layouts/Layout.astro";
import ChangeLogPage from "../ReactPages/ChangeLog.tsx";
---

<AstroLayout title="What's New? | Sudoku Plays">
    <ChangeLogPage client:load />
</AstroLayout>

<script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@graph": [
            {
                "@type": "WebPage",
                "@id": "https://sudokuplays.com/changeLog/#webpage",
                "url": "https://sudokuplays.com/changeLog/",
                "name": "Change Log | Sudoku Plays",
                "description": "Stay updated with the latest features, improvements, and bug fixes for Sudoku Plays. See what's new in our recent updates.",
                "breadcrumb": {
                    "@id": "https://sudokuplays.com/changeLog/#breadcrumb"
                },
                "inLanguage": "en",
                "isPartOf": {
                    "@type": "WebSite",
                    "@id": "https://sudokuplays.com/#website",
                    "name": "Sudoku Plays",
                    "url": "https://sudokuplays.com/"
                }
            },
            {
                "@type": "BreadcrumbList",
                "@id": "https://sudokuplays.com/changeLog/#breadcrumb",
                "itemListElement": [
                    {
                        "@type": "ListItem",
                        "position": 1,
                        "item": {
                            "@type": "WebPage",
                            "@id": "https://sudokuplays.com/",
                            "url": "https://sudokuplays.com/",
                            "name": "Home"
                        }
                    },
                    {
                        "@type": "ListItem",
                        "position": 2,
                        "item": {
                            "@id": "https://sudokuplays.com/changeLog/",
                            "name": "Change Log"
                        }
                    }
                ]
            }
        ]
    }
</script>
