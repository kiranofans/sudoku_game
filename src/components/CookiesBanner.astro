---

<div
    id="cookie-banner"
    class="hidden fixed bottom-5 left-5 right-5 md:left-auto md:max-w-md p-6 rounded-2xl border border-white/20 bg-white/10 backdrop-blur-md shadow-2xl z-50"
>
    <div class="flex flex-col gap-4">
        <div class="text-white">
            <h2 class="text-lg font-bold mb-1">Privacy Preferences</h2>
            <p class="text-sm opacity-90 leading-relaxed">
                We use cookies to improve your experience and show personalized
                ads. Read our <a
                    href="/privacy"
                    class="underline hover:text-blue-300">Privacy Policy</a
                >.
            </p>
        </div>

        <div class="flex gap-3">
            <button
                id="accept-cookies"
                class="flex-1 px-4 py-2 bg-white text-black font-semibold rounded-lg hover:bg-opacity-90 transition-all active:scale-95"
            >
                Accept
            </button>
            <button
                id="decline-cookies"
                class="flex-1 px-4 py-2 bg-black/30 text-white border border-white/20 rounded-lg hover:bg-white/10 transition-all active:scale-95"
            >
                Decline
            </button>
        </div>
    </div>
</div>

<style>
    .hidden {
        display: none;
    }

    #cookie-banner {
        animation: slideUp 0.5s ease-out forwards;
    }

    @keyframes slideUp {
        from {
            transform: translateY(100%);
            opacity: 0;
        }
        to {
            transform: translateY(0);
            opacity: 1;
        }
    }
</style>

<script is:inline>
    const banner = document.getElementById("cookie-banner");
    const acceptBtn = document.getElementById("accept-cookies");
    const declineBtn = document.getElementById("decline-cookies");

    // Check if user has already made a choice
    const consent = localStorage.getItem("cookie-consent");

    if (!consent) {
        banner.classList.remove("hidden");
    }

    acceptBtn.addEventListener("click", () => {
        localStorage.setItem("cookie-consent", "accepted");
        banner.classList.add("hidden");
        window.location.reload(); // Reload to activate AdSense personalization
    });

    declineBtn.addEventListener("click", () => {
        localStorage.setItem("cookie-consent", "declined");
        banner.classList.add("hidden");
        // Ads will stay non-personalized
    });
</script>
